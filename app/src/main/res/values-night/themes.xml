<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema mode gelap diarahkan ke tema Light untuk memaksa Light Mode -->
    <style name="Base.Theme.Fokusku" parent="Theme.Material3.Light.NoActionBar">
        <!-- Warna Utama Aplikasi -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Warna Latar Belakang -->
        <item name="android:windowBackground">@color/cream_bg</item>
        <item name="colorSurface">@color/cream_bg</item>

        <!-- Warna Status Bar -->
        <item name="android:statusBarColor">@color/dark_green</item>

        <!-- Warna Teks Umum -->
        <item name="colorOnSurface">@color/dark_green</item>
    </style>
</resources>
