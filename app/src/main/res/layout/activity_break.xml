<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9"
    tools:context=".BreakActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvBreakLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/break_label"
                android:textColor="@color/dark_green"
                android:textSize="20sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Timer Visual Group -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/timerContainer"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_marginTop="60dp"
                app:layout_constraintTop_toBottomOf="@id/tvBreakLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    style="@style/Widget.Material3Expressive.CircularProgressIndicator.Wavy"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:progress="100"
                    app:indicatorSize="280dp"
                    app:trackThickness="8dp"
                    app:indicatorColor="@color/cream_bg"
                    app:trackColor="#E8F5E9"
                    app:trackCornerRadius="4dp"
                    app:wavelength="40dp"
                    app:waveAmplitude="5dp" />

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/breakProgress"
                    style="@style/Widget.Material3Expressive.CircularProgressIndicator.Wavy"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:progress="600"
                    android:max="1000"
                    app:indicatorSize="280dp"
                    app:trackThickness="8dp"
                    app:indicatorColor="@color/soft_green"
                    app:trackColor="@android:color/transparent"
                    app:trackCornerRadius="4dp"
                    app:wavelength="40dp"
                    app:waveAmplitude="5dp" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_break_timer"
                    android:textColor="@color/dark_green"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/tvQuote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/break_quote"
                android:textColor="@color/dark_green"
                android:alpha="0.7"
                android:textSize="15sp"
                android:textStyle="italic"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/timerContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:layout_marginBottom="16dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/tvQuote"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackToFocus"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/btn_back_to_focus"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary_green"
                    app:cornerRadius="20dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSkipBreak"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="@string/btn_skip_break"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_green"
                    app:strokeColor="@color/soft_green"
                    app:cornerRadius="20dp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
