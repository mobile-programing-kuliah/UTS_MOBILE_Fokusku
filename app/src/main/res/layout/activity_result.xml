<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream_bg"
    tools:context=".ResultActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnBackHome">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="28dp">

            <!-- Hero Section -->
            <ImageView
                android:id="@+id/ivCheck"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="60dp"
                android:src="@drawable/ic_check_circle"
                android:contentDescription="@string/congrats_title"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvCongratsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/congrats_title"
                android:textColor="@color/dark_green"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                app:layout_constraintTop_toBottomOf="@id/ivCheck"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvCongratsMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/congrats_message"
                android:textColor="@color/dark_green"
                android:alpha="0.8"
                android:textSize="18sp"
                android:gravity="center"
                android:fontFamily="sans-serif"
                app:layout_constraintTop_toBottomOf="@id/tvCongratsTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Stats Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/soft_green"
                app:cardBackgroundColor="@android:color/transparent"
                app:layout_constraintTop_toBottomOf="@id/tvCongratsMessage">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="24dp"
                    android:baselineAligned="false">

                    <!-- Time Stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_timer"
                            android:layout_marginBottom="8dp"
                            app:tint="@color/primary_green"
                            android:contentDescription="@string/label_duration" />

                        <TextView
                            android:id="@+id/tvTotalMinutes"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="100"
                            android:textColor="@color/dark_green"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_minutes_focus"
                            android:textColor="@color/dark_green"
                            android:textSize="12sp"
                            android:alpha="0.6"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <!-- Session Stat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_session"
                            android:layout_marginBottom="8dp"
                            app:tint="@color/primary_green"
                            android:contentDescription="@string/label_sessions" />

                        <TextView
                            android:id="@+id/tvTotalSessions"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4 / 4"
                            android:textColor="@color/dark_green"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_sessions_completed"
                            android:textColor="@color/dark_green"
                            android:textSize="12sp"
                            android:alpha="0.6"
                            android:textAllCaps="true"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Encouragement -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="@string/encouragement_message"
                android:textColor="@color/dark_green"
                android:alpha="0.6"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/cardStats"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Action Button (Sticky Bottom) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBackHome"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_margin="28dp"
        android:text="@string/btn_back_home"
        android:textSize="18sp"
        android:textAllCaps="false"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@color/dark_green"
        app:cornerRadius="28dp"
        app:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
